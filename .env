# Firebase Configuration
# Preencha com suas credenciais do Firebase Console (console.firebase.google.com)
# Para Cloudflare Pages: configure essas variáveis no painel Settings > Environment Variables
VITE_FIREBASE_API_KEY=sua_chave_aqui
VITE_FIREBASE_AUTH_DOMAIN=rhythm-trainer.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=rhythm-trainer
VITE_FIREBASE_STORAGE_BUCKET=rhythm-trainer.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=seu_sender_id
VITE_FIREBASE_APP_ID=seu_app_id

# App Configuration
VITE_APP_TITLE=Rhythm Trainer PRO
VITE_APP_VERSION=1.0.0
VITE_DEFAULT_BPM=120

# Identificador lógico da aplicação (usado como namespace no Firestore)
# Mantenha um valor fixo e sem espaços para não perder dados entre deploys
VITE_APP_ID=rhythm-secret
